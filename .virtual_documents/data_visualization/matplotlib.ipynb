# Stack Plot
days = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
direct = [50, 60, 70, 80, 90, 100, 110]
organic = [30, 40, 50, 55, 60, 70, 80]
social = [20, 25, 30, 35, 40, 50, 60]

# Single day plot
# plt.pie([direct[0], organic[0], social[0]], labels=["direct", "organic", "social"], autopct="%1.1f%%")

# For multiple days
